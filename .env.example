# Configurações do Agente Autônomo (Provider Agnóstico)

# Provedor padrão ('openai', 'gemini', 'anthropic', 'openrouter', 'openai_compatible')
AGENT_PROVIDER=openrouter

# Modelo padrão a ser utilizado
# Para Gemini: gemini-2.5-flash
# Para OpenAI: gpt-4o-mini
# Para Anthropic: claude-3-5-sonnet-20241022
# Para OpenRouter: anthropic/claude-3.5-sonnet ou google/gemini-2.5-pro
AGENT_MODEL=anthropic/claude-3.5-sonnet

# Chaves de API correspondentes ao provedor utilizado:
OPENROUTER_API_KEY=seu_token_openrouter_aqui
GEMINI_API_KEY=sua_chave_gemini_aqui
OPENAI_API_KEY=sua_chave_openai_aqui
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui

# Configurações adicionais de endpoints compatíveis com OpenAI (Ollama, Groq, etc.)
OPENAI_BASE_URL=
